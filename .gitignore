# Cloned upstream repos (each has its own git history; not tracked by the umbrella repo)
/repos/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Build / dependency artifacts
node_modules/
__pycache__/
*.pyc
target/
build/
dist/
out/
.gradle/

# Local env / secrets
.env
.env.*
*.local

# Claude Code -> Cursor mission-control watch file (live transcript digest)
.claude/watch.log
# Notify-hook "last seen" marker (local, transient)
.claude/.cursor-review.seen

# Cursor scratch/staging (subagent staging, one-off scripts — not tracked)
/scratch/

# Proof/demo media — large binaries; tracked via docs/PROOF-INDEX.md, uploaded to the submission (not git)
/proof/
*.mp4
*.mov
*.mkv
*.webm
