# Cloned upstream repos (each has its own git history; not tracked by the umbrella repo)
/repos/

# Nested git worktrees created inside the umbrella dir (Claude sometimes places
# anki worktrees here, e.g. anki-mcq-wt, anki-visuals-verify-wt). Each is a full
# anki checkout with its own git history + multi-GB build artifacts — never
# umbrella content. Keep them out of the umbrella SCM view.
/anki-*-wt/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Build / dependency artifacts
node_modules/
__pycache__/
*.pyc
target/
build/
dist/
out/
.gradle/

# Local env / secrets
.env
.env.*
*.local

# Claude Code -> Cursor mission-control watch file (live transcript digest)
.claude/watch.log
# Notify-hook "last seen" marker (local, transient)
.claude/.cursor-review.seen

# Cursor scratch/staging (subagent staging, one-off scripts — not tracked)
/scratch/

# Proof/demo media — large binaries; tracked via docs/PROOF-INDEX.md, uploaded to the submission (not git)
/proof/
*.mp4
*.mov
*.mkv
*.webm

# Cursor<->Claude scratch artifacts (not part of the project)
.claude/*.patch
.claude/*.png
